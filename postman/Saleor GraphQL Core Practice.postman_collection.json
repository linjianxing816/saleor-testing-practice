  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const baseUrl = pm.environment.get(\"base_url\");\r",
          "const email = pm.environment.get(\"admin_email\") || \"admin@example.com\";\r",
          "const password = pm.environment.get(\"admin_password\") || \"admin\";\r",
          "\r",
          "pm.sendRequest({\r",
          "    url: baseUrl,\r",
          "    method: \"POST\",\r",
          "    header: {\r",
          "        \"Content-Type\": \"application/json\"\r",
          "    },\r",
          "    body: {\r",
          "        mode: \"raw\",\r",
          "        raw: JSON.stringify({\r",
          "            query: `mutation {\r",
          "                tokenCreate(email: \"${email}\", password: \"${password}\") {\r",
          "                    token\r",
          "                    refreshToken\r",
          "                    user {\r",
          "                        id\r",
          "                        email\r",
          "                    }\r",
          "                    errors {\r",
          "                        field\r",
          "                        message\r",
          "                        code\r",
          "                    }\r",
          "                }\r",
          "            }`\r",
          "        })\r",
          "    }\r",
          "}, function (err, res) {\r",
          "    if (err) {\r",
          "        console.log(\"Auto login request failed:\", err);\r",
          "        return;\r",
          "    }\r",
          "\r",
          "    const json = res.json();\r",
          "\r",
          "    if (\r",
          "        json.data &&\r",
          "        json.data.tokenCreate &&\r",
          "        json.data.tokenCreate.token\r",
          "    ) {\r",
          "        pm.environment.set(\"access_token\", json.data.tokenCreate.token);\r",
          "        pm.environment.set(\"refresh_token\", json.data.tokenCreate.refreshToken);\r",
          "        console.log(\"Auto login success, token saved.\");\r",
          "    } else {\r",
          "        console.log(\"Auto login failed:\", JSON.stringify(json));\r",
          "    }\r",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
