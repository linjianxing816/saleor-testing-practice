      "name": "09_product_variants_query",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"response has no graphql errors\", function () {\r",
              "    pm.expect(res.errors, JSON.stringify(res.errors)).to.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"products exists\", function () {\r",
              "    pm.expect(res.data.products).to.not.eql(null);\r",
              "});\r",
              "\r",
              "pm.test(\"products edges is array\", function () {\r",
              "    pm.expect(res.data.products.edges).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "let variantId = null;\r",
              "\r",
              "for (const edge of res.data.products.edges) {\r",
              "    const product = edge.node;\r",
              "\r",
              "    if (product.variants && product.variants.length > 0) {\r",
              "        variantId = product.variants[0].id;\r",
              "\r",
              "        pm.environment.set(\"variant_id\", variantId);\r",
              "        pm.environment.set(\"product_id\", product.id);\r",
              "        pm.environment.set(\"product_name\", product.name);\r",
              "\r",
              "        break;\r",
              "    }\r",
              "}\r",
              "\r",
              "pm.test(\"at least one product variant exists\", function () {\r",
              "    pm.expect(variantId).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
