          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="断言_checkout_id存在" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="1116933">&quot;id&quot;</stringProp>
